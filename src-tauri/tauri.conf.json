{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Canvas Pocket",
  "version": "0.1.0",
  "identifier": "dev.canvas.pocket",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Canvas Pocket",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Canvas@SJTU 课程录像下载",
    "longDescription": "上海交通大学 Canvas 课程课堂录像下载工具",
    "category": "Utility"
  }
}

