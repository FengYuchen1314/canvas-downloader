{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Canvas Pocket",
  "version": "0.1.0",
  "identifier": "dev.canvas.pocket",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Canvas Pocket",
        "width": 1180,
        "height": 780,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}

